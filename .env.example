APP_ENV=dev
LOG_LEVEL=INFO

# Core paths
INPUT_DIR=data/input
OUTPUT_DIR=data/output
DEFAULT_OUTPUT_FILE=data/output/assistant_output.xlsx

# Assistant runtime mode
LLM_MODE=mock
AI_PROVIDER=rule_based
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5.5

# Required portfolio placeholders (never put real keys here)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_BASE_URL=
OPENROUTER_BASE_URL=

# Optional app settings
OPENAI_MODEL=gpt-5.5
COUNTRY_API_MODE=worldbank
COUNTRY_API_BASE_URL=https://api.worldbank.org/v2
REQUEST_TIMEOUT_SECONDS=10
STREAMLIT_MAX_UPLOAD_MB=50
